<html>
<head>
<style>
body{
margin:0;
background:#071a3a;
overflow:hidden;
font-family:Arial;
text-align:center;
color:white;
}

h1{
position:absolute;
top:40px;
width:100%;
color:#ffd700;
text-shadow:0 0 20px gold;
}

.moon{
position:absolute;
top:80px;
right:120px;
font-size:80px;
animation:float 4s infinite alternate;
}

.star{
position:absolute;
color:white;
animation:twinkle 2s infinite alternate;
}

.rose{
position:absolute;
bottom:0;
font-size:35px;
}

.tree{
position:absolute;
bottom:0;
font-size:60px;
}

@keyframes twinkle{
from{opacity:0.2;}
to{opacity:1;}
}

@keyframes float{
from{transform:translateY(0);}
to{transform:translateY(-15px);}
}
</style>
</head>

<body>

<h1>Ramadan Mubarak 🌙</h1>

<div class="moon">🌙</div>

<div class="tree" style="left:5%">🌳</div>
<div class="tree" style="left:85%">🌳</div>

<div class="rose" style="left:20%">🌹</div>
<div class="rose" style="left:30%">🌹</div>
<div class="rose" style="left:40%">🌹</div>
<div class="rose" style="left:60%">🌹</div>
<div class="rose" style="left:70%">🌹</div>

<script>
for(let i=0;i<40;i++){
let star=document.createElement("div");
star.innerHTML="⭐";
star.className="star";
star.style.left=Math.random()*100+"%";
star.style.top=Math.random()*80+"%";
document.body.appendChild(star);
}
</script>

</body>
</html>